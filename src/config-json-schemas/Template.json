{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "extendsTemplate": { "type": "string" },
    "inputs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/TypeConfigurationV2" }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "definitions": {
    "TypeConfigurationV2": {
      "type": "object",
      "required": [ "type" ],
      "properties": {
        "type": {
          "enum": [ "object",  "array",  "string",  "number", "boolean"  ]
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "object" }
            }
          },
          "then": { "$ref": "#/definitions/ObjectConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "array" }
            }
          },
          "then": { "$ref": "#/definitions/ArrayConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "string" }
            }
          },
          "then": { "$ref": "#/definitions/StringConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "number" }
            }
          },
          "then": { "$ref": "#/definitions/NumberConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "boolean" }
            }
          },
          "then": { "$ref": "#/definitions/BooleanConfigurationV2" }
        }
      ]
    },
    "ObjectConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "type", "properties" ],
      "properties": {
        "type": { "const": "object" },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/TypeConfigurationV2" }
        }
      }
    },
    "ArrayConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "array" },
        "items": {"$ref": "#/definitions/TypeConfigurationV2" }
      }
    },
    "StringConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "type" ],
      "properties": {
        "type": { "const": "string" }
      }
    },
    "NumberConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type" ],
      "properties": {
        "type": { "const": "number" }
      }
    },
    "BooleanConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "type" ],
      "properties": {
        "type": { "const": "boolean" }
      }
    }
  }
}
