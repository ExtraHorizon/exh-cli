{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "extendsTemplate": { "type": "string" },
    "inputs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/TypeConfiguration" }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "variables": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "definitions": {
    "TypeConfiguration": {
      "type": "object",
      "required": [ "type" ],
      "properties": {
        "type": {
          "enum": [ "object",  "array",  "string",  "number", "boolean"  ]
        }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "object" }
            }
          },
          "then": { "$ref": "#/definitions/ObjectConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "array" }
            }
          },
          "then": { "$ref": "#/definitions/ArrayConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "string" }
            }
          },
          "then": { "$ref": "#/definitions/StringConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "number" }
            }
          },
          "then": { "$ref": "#/definitions/NumberConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "boolean" }
            }
          },
          "then": { "$ref": "#/definitions/BooleanConfiguration" }
        }
      ]
    },
    "ObjectConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "type", "properties" ],
      "properties": {
        "type": { "const": "object" },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/TypeConfiguration" }
        }
      }
    },
    "ArrayConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "array" },
        "items": {"$ref": "#/definitions/TypeConfiguration" }
      }
    },
    "StringConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "type" ],
      "properties": {
        "type": { "const": "string" }
      }
    },
    "NumberConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type" ],
      "properties": {
        "type": { "const": "number" }
      }
    },
    "BooleanConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "type" ],
      "properties": {
        "type": { "const": "boolean" }
      }
    }
  }
}
