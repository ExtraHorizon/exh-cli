{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "if": {
    "description": "Try to determine if we have V1 schema",
    "anyOf": [
      {
        "type": "object",
        "required": ["version"],
        "properties": { "version": { "const": 1 }}
      },
      {
        "type": "object",
        "required": ["schema"],
        "properties": {
          "version": { "const": 1 },
          "schema": true
        }
      },
      {
        "type": "object",
        "required": ["fields"],
        "properties": {
          "version": { "const": 1 },
          "fields": true
        }
      }
    ]
  },
  "then": { "$ref": "#/definitions/TemplateV1" },
  "else": { "$ref": "#/definitions/TemplateV2" },
  
  "definitions": {
    "TemplateV2": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "version": { "const": 2 },
        "$schema": { "type": "string" },
        "description": { "type": "string" },
        "extendsTemplate": { "type": "string" },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/TypeConfigurationV2" }
        },
        "outputs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "TypeConfigurationV2": {
      "type": "object",
      "properties": {
        "type": { "enum": ["object", "array", "string", "number", "boolean"] }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "object" }
            }
          },
          "then": { "$ref": "#/definitions/ObjectConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "array" }
            }
          },
          "then": { "$ref": "#/definitions/ArrayConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "string" }
            }
          },
          "then": { "$ref": "#/definitions/StringConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "number" }
            }
          },
          "then": { "$ref": "#/definitions/NumberConfigurationV2" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "boolean" }
            }
          },
          "then": { "$ref": "#/definitions/BooleanConfigurationV2" }
        }
      ]
    },
    "ObjectConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "properties"],
      "properties": {
        "type": { "const": "object" },
        "properties": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/TypeConfigurationV2" }
        }
      }
    },
    "ArrayConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "items"],
      "properties": {
        "type": { "const": "array" },
        "items": { "$ref": "#/definitions/TypeConfigurationV2" }
      }
    },
    "StringConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "string" }
      }
    },
    "NumberConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "number" }
      }
    },
    "BooleanConfigurationV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "boolean" }
      }
    },
    "TemplateV1": {
      "type": "object",
      "required": ["description", "schema", "fields"],
      "properties": {
        "version": { "const": 1 },
        "$schema": { "type": "string" },
        "extends_template": { "type": "string" },
        "description": { "type": "string" },
        "schema": { "$ref": "#/definitions/ObjectConfiguration" },
        "fields": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "TypeConfiguration": {
      "type": "object",
      "properties": {
        "type": { "enum": ["object", "array", "string", "number", "boolean"] }
      },
      "allOf": [
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "object" }
            }
          },
          "then": { "$ref": "#/definitions/ObjectConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "array" }
            }
          },
          "then": { "$ref": "#/definitions/ArrayConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "string" }
            }
          },
          "then": { "$ref": "#/definitions/StringConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "number" }
            }
          },
          "then": { "$ref": "#/definitions/NumberConfiguration" }
        },
        {
          "if": {
            "type": "object",
            "properties": {
              "type": { "const": "boolean" }
            }
          },
          "then": { "$ref": "#/definitions/BooleanConfiguration" }
        }
      ]
    },
    "ObjectConfiguration": {
      "type": "object",
      "properties": {
        "type": { "const": "object" },
        "fields": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/TypeConfiguration"
          }
        }
      }
    },
    "ArrayConfiguration": {
      "type": "object",
      "properties": {
        "type": { "const": "array" },
        "items": { "$ref": "#/definitions/TypeConfiguration" }
      }
    },
    "StringConfiguration": {
      "type": "object",
      "properties": {
        "type": { "const": "string" }
      }
    },
    "NumberConfiguration": {
      "type": "object",
      "properties": {
        "type": { "const": "number" }
      }
    },
    "BooleanConfiguration": {
      "type": "object",
      "properties": {
        "type": { "const": "boolean" }
      }
    }
  }
}